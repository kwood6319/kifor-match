<nav class="navbar">
  <div class="logo">
    <%= link_to "#", class: "navbar-brand" do %>
      <%= image_tag "kifor logo.png", class: "logo" %>
    <% end %>
  </div>
  <ul class="nav-menu">
    <% if user_signed_in? %>
      <li class="nav-item active">
        <% if current_user.admin? || current_user.donor? %>
          <%= link_to "Requests", requests_path, class: "nav-link" %>
        <% end %>
      </li>
      <li class="nav-item active">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", dynamic_dashboard_path(current_user), class: "nav-link" %>
        <% else %>
          <%= link_to "Login", new_user_session_path %>
        <% end %>
      </li>
      <% if current_user.admin? %>
        <li>
          <%= link_to "Charities", charities_path, class: "nav-link" %>
        </li>
        <li>
          <%= link_to "Donors", donors_path, class: "nav-link" %>
        </li>
      <% end %>
      <li>
        <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
      </li>
    <% else %>
      <li class="nav-item">
        <%= link_to "Login", new_user_session_path, class: "nav-link" %>
      </li>
    <% end %>
  </ul>
</nav>
