<nav class="navbar">
  <div class="logo">
    <%= link_to "https://www.kifor.jp/", class: "navbar-brand" do %>
      <%= image_tag "kifor logo.png", class: "logo" %>
    <% end %>
  </div>
  <ul class="nav-menu">
    <% if user_signed_in? %>
      <li class="nav-item active">
        <% if user_signed_in? %>
          <%= link_to t("navigation.dashboard"), dynamic_dashboard_path(current_user), class: "nav-link" %>
        <% else %>
          <%= link_to t("navigation.login"), new_user_session_path %>
        <% end %>
      </li>
      <% if current_user.admin? %>
        <li>
          <%= link_to t("navigation.charities"), charities_path, class: "nav-link" %>
        </li>
        <li>
          <%= link_to t("navigation.donors"), donors_path, class: "nav-link" %>
        </li>
      <% end %>
      <li>
        <%= link_to t("navigation.sign_out"), destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
      </li>
    <% else %>
      <li class="nav-item">
        <%= link_to t("navigation.login"), new_user_session_path, class: "nav-link" %>
      </li>
    <% end %>
    <li>
      <% if I18n.locale == :ja %>
        <%= link_to "English", url_for(locale: :en), data: { turbo_action: "replace"} %>
      <% else %>
        <%= link_to "日本語", url_for(locale: :ja), data: {turbo_action: "replace"} %>
      <% end %>
    </li>
  </ul>
</nav>
