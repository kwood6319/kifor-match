<div class="container mt-5 mb-4">
  <div class="mb-3">
    <%= link_to "← Back", "#", data: { controller: "history", action: "click->history#back" }, class: "btn btn-outline-secondary" %>
  </div>
  <div class="row align-items-stretch g-4">
    <div class="col-lg-5">
      <div class="tall-card p-3 h-100">
        <div class="row pt-2">
          <div class="col-8">
            <h2> <%=@request.title %> </h2>
          </div>
          <div class="col-4 text-center">
            <h3> x<%= @request.quantity_remaining %> </h3>
            <div class="badge rounded-pill pill-<%=@request.urgency%>">
              <%= t("urgencies.#{@request.urgency}") %>
            </div>
          </div>
        </div>
        <div>
          <p> <i class="fa-solid fa-location-dot"></i> <%= t("regions.#{@request.charity.region}") %> - <%= t("prefectures.#{@request.charity.prefecture}") %> </p>
        </div>
        <div>
          <h5> <%= t("navigation.condition") %>: </h4>
          <% @request.acceptable_conditions.each do |cond| %>
            <p class="mb-0"> <%= t("conditions.#{cond}") %> </p>
          <% end %>
          <br>
        </div>
        <div>
          <h5> <%= t("navigation.description") %>: </h4>
          <p> <%= @request.description %> </p>
        </div>
        <% if policy(@request).edit? %>
          <%= link_to "Edit Request", edit_request_path(@request), class: "btn btn-outline-secondary" %>
        <% end %>
      </div>
    </div>
    <div class="col-lg-6 mx-3">
      <% if current_user.charity? && current_user.charity == @request.charity %>
        <%= render "currentcharityrequest", request: @request %>
      <% elsif @editing_offer == @my_offer %>
        <%= render "offers/form", request: @request, offer: @my_offer %>
      <% elsif @my_offer.present? %>
        <%= render 'currentdonorexistingoffer', request: @request, offer: @my_offer %>
      <div class="d-flex gap-2 mt-2">
        <% if %w]submitted approved rejected].include?(@my_offer.status.to_s) %>
          <%= link_to t("buttons.edit_offer"),
          request_path(@request, edit_offer: @my_offer.id),
          class: "btn btn-secondary" %>
        <% end %>

        <% if %w[submitted rejected].include?(@my_offer.status.to_s) %>
          <button type="button"
              class="btn btn-danger"
              data-bs-toggle="modal"
              data-bs-target="#deleteOfferModal"
              data-delete-url="<%= offer_path(@my_offer) %>">
              <%= t("buttons.delete") %>
            </button>
        <% end %>

      </div>
      <% elsif policy(Offer.new(request: @request)).new?%>
        <%= render 'offers/form', request: @request, offer: @offer, locals: { custom_class: "new-offer" } %>
      <% end %>
    </div>
  </div>
</div>
<%# ------------------ %>

<%# Rejection modal %>
<div class="modal fade"
      id="rejectOfferModal"
      tabindex="-1"
      aria-hidden="true"
      data-controller="reject-offer">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><%= t("modals.reject_offer.title") %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <%= form_tag "#", method: :patch, id: "rejectOfferForm" do %>
        <div class="modal-body">
          <div class="mb-3">
            <%= label_tag :rejection_reason, t("activerecord.attributes.offer.rejection_reason"), class: "form-label" %>
            <%= text_area_tag :rejection_reason, nil, class: "form-control", rows: 4, id: "rejection_reason" %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><%= t("buttons.cancel") %></button>
          <%= submit_tag t("buttons.reject_offer"), class: "btn btn-danger" %>
        </div>
      <% end %>
    </div>
  </div>
</div>


<%# Delete modal %>
<div class="modal fade"
      id="deleteOfferModal"
      tabindex="-1"
      aria-hidden="true"
      data-controller="delete-offer">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><%= t("modals.delete_offer.title") %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <%= form_tag "#", method: :delete, id: "deleteOfferForm" do %>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><%= t("buttons.cancel") %></button>
          <%= submit_tag t("buttons.delete"), class: "btn btn-danger" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
