<div class="container mt-5 mb-4">
  <h3>Welcome back, <%= current_user.email.gsub(/@.*$/, "").capitalize %>!</h3>
</div>
<div class="container d-flex justify-content-center">
  <div class="row justify-content-center gap-3">
    <div class="request-card card col-sm-12 col-md-9 col-lg-3">
      <div class="request-card-infos">
        <i class="fa-solid fa-plus"></i>
        <span>Make a new request here!</span>
      </div>
      <%= link_to "New Request", new_request_path, class: "btn btn-secondary" if policy(Request).new? %>
    </div>
    <% @requests.each do |request| %>
      <div class="request-card card col-sm-12 col-md-9 col-lg-3">
        <div class="request-card-infos">
          Title: <%= request.title %><br>
          Status: <%= request.status %><br>
          City: <%= request.city %><br>
          Condition: <%= request.condition %><br>
          Quantity Needed: <%= request.quantity_needed %><br>
          Quantity Remaining: <%= request.quantity_remaining %><br>
        </div>
        <%= link_to "View Request", request_path(request), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
