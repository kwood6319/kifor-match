<h2> Offers </h2>
<% if @offers.empty? %>
  No offers yet
<% else %>
  <% @offers.each do |offer| %>
    <div class="small-card offer-card p-2 mb-3
              <%= 'rejected-offer' if offer.status == 'rejected' %>">
      <div class="row">
        <div class="col-5">
          <% if offer.photo.attached? %>
            <%= image_tag offer.photo, class: "img-fluid rounded" %>
          <% else %>
            <div class="offer-image-placeholder">
              📷 No image
            </div>
          <% end %>
        </div>
        <div class="col-7">
          <div class="row">
            <div class="col-9">
              <h3> <%= offer.donor.display_name %> </h3>
            </div>
            <div class="col-3">
              <h3> <%= offer.quantity_offered %> </h3>
            </div>
          </div>
          <p class="mb-0"> <i class="fa-solid fa-location-dot"></i> <%= offer.donor.region if offer.donor.region %> </p>
          <p class="mb-0"> <strong> Condition: </strong> <%= offer.condition %> </p>
          <p class="mb-0"> <strong> Can be sent: </strong> <%= offer.can_ship_by ? offer.can_ship_by.strftime("%b %e") : "N/A" %> </p>
          <p class="mb-0"> <strong> Message: </strong> <%= offer.message %> </p>
          <% if offer.status == "submitted" %>
            <div class="row mt-1">
              <div class="col-lg-6">
                <% if policy(offer).approve? %>
                  <%= button_to "Approve Offer", approve_offer_path(offer), method: :patch, class: "btn btn-success" %>
                <% end %>
              </div>
              <div class="col-lg-6">
                <% if policy(offer).reject? %>
                  <%= button_to "Reject Offer", reject_offer_path(offer), method: :patch, class: "btn btn-danger" %>
                <% end %>
              </div>
            </div>
          <% elsif offer.status == "approved"%>
            <p class="mb-0"> <strong> Estimated arrival: </strong> <%= offer.estimated_arrival %></p>
            <p class="mb-0"> <strong> Tracking information: </strong> <%= offer.tracking_number %> </p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
