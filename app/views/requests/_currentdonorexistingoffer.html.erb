<h3> Your offer has been submitted: </h3>
<div class="small-card offer-card p-2 mb-3
  <%= 'rejected-offer' if offer.status == 'rejected' %>">
  <div class="row">
    <div class="col-5">
      <% if offer.photo.attached? %>
        <div class="offer-image">
          <%= image_tag offer.photo, class: "img-fluid rounded" %>
        </div>
      <% else %>
        <div class="offer-image-placeholder">
          📷 No image
        </div>
      <% end %>
    </div>
    <div class="col-7">
      <div class="row">
        <div class="col-9">
          <h4> <%= request.title %> </h4>
        </div>
        <div class="col-3">
          <h4> <%= offer.quantity_offered %> </h4>
        </div>
      </div>
      <p class="mb-0"> <i class="fa-solid fa-location-dot"></i> <%= offer.donor.region if offer.donor.region %> </p>
      <p class="mb-0"> <strong> Condition: </strong> <%= offer.condition %> </p>
      <% if offer.can_ship_by %>
        <p class="mb-0"> <strong> Can be sent: </strong> <%= offer.can_ship_by.strftime("%b %e") %> </p>
      <% end %>
      <% if offer.message != "" %>
        <p class="mb-0"> <strong> Message: </strong> <%= offer.message %> </p>
      <% end %>
    </div>
  </div>
  <h5 class="mt-2"> Status: </h5>
  <p> <%= offer.status %> </p>
  <% if offer.status == "submitted" %>
    <p> We are currently awaiting the charity's response. We'll let you know when they respond! </p>
  <% elsif offer.status == "approved" %>
    <p> Please send the item and then fill in the following information: </p>
    <p> Arrives: <%= offer.estimated_arrival %> </p>
    <p> <%= offer.tracking_number %> </p>
    <%= simple_form_for offer,
      url: mark_as_shipped_offer_path(offer),
      method: :patch do |f| %>
      <div class="row">
        <div class="col-md-6">
          <%= f.input :estimated_arrival, label: "Estimated Arrival", as: :date, html5: true %>
        </div>
        <div class="col-md-6">
          <%= f.input :tracking_number, label: "Tracking information", placeholder: "Enter tracking number" %>
        </div>
      </div>
      <%= f.submit "Save shipping info",
        class: "btn btn-primary mt-3" %>
    <% end %>
  <% elsif offer.status == "rejected" %>
    <p> Thank you for your offer, but the charity has decided to decline this time. </p>
  <% elsif offer.status == "shipped" %>
    <p> The charity has received your information. For your own notes: </p>
    <p> Estimated arrival: <%= offer.estimated_arrival %> </p>
    <p> Tracking information: <%= offer.tracking_number %> </p>
  <% elsif offer.status == "received" %>
    <p> Your item has been marked as received by the charity. Thank you, from the bottom of our hearts. ♡
    <% end %>
  </div>
