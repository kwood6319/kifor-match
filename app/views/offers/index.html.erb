<% content_for :title, "Offers" %>
<h1>Offers</h1>

<% status_badge = lambda do |status| %>
  <% normalized_status = status.to_s.strip.downcase %>
  <% label = normalized_status.capitalize %>
  <% badge_class = case normalized_status %>
  <% when "pending" %>
    <% "status-badge status-badge--pending" %>
  <% when "approved" %>
    <% "status-badge status-badge--approved" %>
  <% when "rejected" %>
    <% "status-badge status-badge--rejected" %>
  <% when "shipped" %>
    <% "status-badge status-badge--shipped" %>
  <% when "received" %>
    <% "status-badge status-badge--received" %>
  <% else %>
    <% "status-badge" %>
  <% end %>
  <%= content_tag(:span, label, class: badge_class) %>
<% end %>

<% if @viewer_role == :donor %>
  <table>
    <thead>
      <tr>
        <th>Request</th>
        <th>Quantity Offered</th>
        <th>Status</th>
        <th>Can Ship By</th>
        <th>Details</th>
      </tr>
    </thead>
    <tbody>
      <% @offers.each do |offer| %>
        <tr>
          <% request = offer.request %>
          <td>
            <div><%= request.title %></div>
            <div>Charity: <%= request.charity.org_name %></div>
            <div>Units: <%= request.units %></div>
            <% if request.quantity_remaining.present? %>
              <div>Quantity remaining: <%= request.quantity_remaining %></div>
            <% end %>
          </td>
          <td><%= offer.quantity_offered %></td>
          <td><%= status_badge.call(offer.status) %></td>
          <td><%= offer.can_ship_by %></td>
          <td>
            <%= link_to "View", offer_path(offer)%>
            <% if offer.status.to_s == "approved" && request.donor_id == @donor.id %>
            <%= button_to "Mark as Shipped", mark_as_shipped_offer_path(offer), method: :patch %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if @viewer_role == :charity %>
  <table>
    <thead>
      <tr>
        <th>Request</th>
        <th>Quantity Offered</th>
        <th>Status</th>
        <th>Can Ship By</th>
        <th>Details</th>
      </tr>
    </thead>
    <tbody>
      <% @offers.each do |offer| %>
        <tr>
          <% request = offer.request %>
          <td>
            <div><%= request.title %></div>
            <div>Charity: <%= request.charity.org_name %></div>
            <div>Units: <%= request.units %></div>
            <% if request.quantity_remaining.present? %>
              <div>Quantity remaining: <%= request.quantity_remaining %></div>
            <% end %>
            <% donor = offer.donor %>
            <div>Donor: <%= donor.display_name %></div>
            <div>Region: <%= donor.region %></div>
            <div>City: <%= donor.city %></div>
          </td>
          <td><%= offer.quantity_offered %></td>
          <td><%= status_badge.call(offer.status) %></td>
          <td><%= offer.can_ship_by %></td>
          <td>
            <%= link_to "View", offer_path(offer) %>
            <% if offer.status.to_s == "pending" && request.charity_id == @charity.id %>
            <%= button_to "Approve", approve_offer_path(offer), method: :patch %>
            <% end %>
            <% if offer.status.to_s == "pending" && request.charity_id == @charity.id %>
            <%= button_to "Reject", reject_offer_path(offer), method: :patch %>
            <% end %>
            <% if offer.status.to_s == "shipped" && request.charity_id == @charity.id %>
            <%= button_to "Mark as Received", mark_as_received_offer_path(offer), method: :patch %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

