<div class="container mt-3 mb-4">
  <h3><%= t("messages.welcome_back") %>, <%= current_user.email.gsub(/@.*$/, "").capitalize %><%="様" if I18n.locale == :ja %>! <%= t("messages.top_categories") %>:</h3>
</div>
<div class="container-fluid mt-4">
  <div class="row mb-4">
    <!-- Left grid -->
    <div class="col-md-8">
      <div class="row row-cols-3 g-3">
        <% @top_categories.each do |key| %>
          <% category_data = CategoryList::CATEGORIES[key] %>
          <% next unless category_data %>
          <div class="col">
            <%= link_to requests_path(category: [key]), class: "text-decoration-none text-dark" do %>
              <div class="card text-center h-100 bg-light border-0 py-4">
                <div class="card-body d-flex flex-column justify-content-center align-items-center">
                  <% icon = CategoryList::CATEGORIES[key][:icons].first %>
                  <% if icon %>
                    <i class="fa-solid <%= icon %> fa-3x mb-2"></i>
                  <% end %>
                  <p class="card-text fs-5 mb-0"><%= CategoryList.label_for(key) %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        <div class="col">
          <%= link_to requests_path, class: "text-decoration-none text-dark" do %>
            <div class="card text-center h-100 bg-light border-0 py-4">
              <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <i class="fa-solid fa-ellipsis fa-3x mb-2"></i>
                <p class="card-text fs-5 mb-0"><%= t("categories.all") %> </p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <%# Right column %>
    <div class="col-md-4 d-flex">
      <div class="card bg-light border-0 w-100" style="max-height: 80vh; overflow-y: auto;">
        <div class="card-body">
          <h5 class="card-title mb-3"><%= t("dashboard.pending") %>:</h5>
          <% if @pending_offers.any? %>
            <% @pending_offers.each do |offer| %>
              <%= link_to request_path(offer.request), class: "text-decoration-none text-dark" do %>
                <div class="pending-item mb-3 pb-3 border-bottom">
                  <div class="d-flex justify-content-between align-items-start">
                    <strong><%= offer.request.title %></strong>
                    <div class="text-nowrap">
                      <span class="badge rounded-pill bg-danger"><%= time_ago_badge(offer.updated_at) %></span>
                      <span class="ms-1 text-muted">x<%= offer.quantity_offered %></span>
                    </div>
                  </div>
                  <p class="mb-1">
                    <%= t("regions.#{offer.request.charity.region}") %> - <%= t("prefectures.#{offer.request.charity.prefecture}") %>
                  </p>
                  <p class="mb-1">
                    <strong><%= t("dashboard.condition") %>:</strong> <%= t("conditions.#{offer.condition}") %>
                  </p>
                  <% if offer.can_ship_by.present? %>
                    <p class="mb-1">
                      <strong><%= t("dashboard.can_ship_by") %>:</strong> <%= offer.can_ship_by.strftime("%b %-d") %>
                    </p>
                  <% end %>
                  <p class="mb-0">
                    <strong><%= t("dashboard.alerts") %>:</strong> <%= offer.alert_message %>
                  </p>
                </div>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-muted mb-0"><%= t("dashboard.no_pending_offers") %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
<%# Toast notification %>
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080">
  <% @notifications.each do |notification|%>
    <%= turbo_frame_tag "notification_#{notification.id}" do %>
      <div class="toast show mb-2" role="alert" id="notification_<%= notification.id %>">
        <div class="toast-header">
          <strong class="me-auto"><%= t("notification.title") %></strong>
          <%= button_to notification_dismiss_path(notification), method: :patch, class: "btn-close", form: { data: { turbo_frame: "notification_#{note.id}" } } %>
        </div>
        <div class="toast-body">
          <%= link_to notification.message, notification.link_path, class: "text-decoration-none" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
