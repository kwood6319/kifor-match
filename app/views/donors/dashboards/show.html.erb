<div class="container mt-3 mb-4">
  <h3><%= t("messages.welcome_back") %>, <%= current_user.email.gsub(/@.*$/, "").capitalize %><%="様" if I18n.locale == :ja %>! <%= t("messages.top_categories") %>:</h3>
</div>
<div class="container-fluid mt-4">
  <div class="row mb-4">
    <!-- Left grid -->
    <div class="col-md-8">
      <div class="row row-cols-3 g-3">
        <% @top_categories.each do |key| %>
          <% category_data = CategoryList::CATEGORIES[key] %>
          <% next unless category_data %>
          <div class="col">
            <%= link_to requests_path(category: [key]), class: "text-decoration-none text-dark" do %>
              <div class="card text-center h-100 bg-light border-0 py-4">
                <div class="card-body d-flex flex-column justify-content-center align-items-center">
                  <% icon = CategoryList::CATEGORIES[key][:icons].first %>
                  <% if icon %>
                    <i class="fa-solid <%= icon %> fa-3x mb-2"></i>
                  <% end %>
                  <p class="card-text fs-5 mb-0"><%= CategoryList.label_for(key) %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
        <div class="col">
          <%= link_to requests_path, class: "text-decoration-none text-dark" do %>
            <div class="card text-center h-100 bg-light border-0 py-4">
              <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <i class="fa-solid fa-ellipsis fa-3x mb-2"></i>
                <p class="card-text fs-5 mb-0"><%= t("categories.all") %> </p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <!-- Right panel -->
    <div class="col-md-4">
      <div class="card bg-light border-0" style="max-height: 80vh; overflow-y: auto;">
        <div class="card-body">
          <h5 class="card-title">Pending:</h5>
          <% 5.times do  %>
            <div class="pending-item mb-3 pb-3 border-bottom">
              <div class="d-flex justify-content-between align-items-start">
                <strong>#{offer_title}</strong>
                <span class="badge rounded-pill bg-danger">7 days ago</span>
              </div>
              <p class="mb-1">Kanto - Tokyo</p>
              <p class="mb-1"><strong>Condition:</strong> Used - Good</p>
              <p class="mb-1"><strong>Can ship by:</strong> Jul 3</p>
              <p class="mb-0"><strong>Alerts:</strong> Shipping info needed</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
