<h1>Donors</h1>
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Type</th>
      <th>Region</th>
      <th>Prefecture</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% @donors.each do |donor| %>
      <tr>
        <td>
          <%= donor.display_name %>
          <% if donor.approved? %>
            <i class="fas fa-shield" style="color: green;"></i>
          <% end %>
        </td>
        <td><%= donor.donor_type %></td>
        <td><%= donor.region %></td>
        <td><%= donor.prefecture %></td>
        <td>
          <% unless donor.approved? %>
            <%= button_to "Approve", approve_donor_path(donor), class: "btn btn-success btn-sm", method: :patch, data: { confirm: "Approve donor?" } %>
          <% end %>
          <%= button_to "Delete", donor_path(donor), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
